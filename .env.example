# NIBS Bursary Management System — Environment Configuration
# Copy this file to .env and fill in your values.

# Application
APP_NAME="NIBS Bursary Management System"
APP_ENV=production
APP_DEBUG=false
APP_URL=http://localhost:8000

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nibs_bursary
DB_USERNAME=root
DB_PASSWORD=

# Session
SESSION_LIFETIME=1800
SESSION_SECURE=false
SESSION_SAMESITE=Strict
